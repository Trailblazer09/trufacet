# ─────────────────────────────────────────────────────────────
# TruFacet configuration
# Copy this file to `.env.local` and fill in your key.
# ─────────────────────────────────────────────────────────────

# Groq is the default LLM provider. It is FREE — get a key at
# https://console.groq.com/keys  (no credit card required).
GROQ_API_KEY=

# Optional: override the Groq model (default is a fast, capable Llama).
# GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────────────────────
# Optional alternative provider. Leave blank to use Groq.
# If set, TruFacet will use Anthropic instead. This is PAID and is
# never required — the free demo runs entirely on Groq.
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
